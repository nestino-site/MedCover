# ─── Traffic Engine (NestJS backend) ───────────────────────────────────────────
# Full base URL including /api/v1 — no trailing slash
# TRAFFIC_ENGINE_URL is preferred; API_BASE_URL is supported as a legacy alias.
TRAFFIC_ENGINE_URL=https://nestino-backend-production.up.railway.app/api/v1
# API_BASE_URL=https://nestino-backend-production.up.railway.app/api/v1

# Site credentials (obtained from POST /api/v1/sites in the backend admin)
SITE_API_KEY=your-site-api-key-here
SITE_ID=2

# ─── Revalidation Webhook ──────────────────────────────────────────────────────
# Must match Site.publishWebhookSecret stored in the backend database (site id 2).
# Backend Site.publishWebhookUrl (use www + trailing slash):
#   https://www.medcover.io/api/webhooks/publish/
WEBHOOK_SECRET=your-shared-webhook-secret-here

# ─── Cache TTL ─────────────────────────────────────────────────────────────────
# How long (seconds) the Next.js fetch cache keeps pages before a background
# refresh. Set lower during development. Webhook revalidation bypasses this.
CONTENT_REVALIDATE_SECONDS=3600

# Optional: fetch timeout in ms (default 60000 dev / 30000 production)
TRAFFIC_ENGINE_FETCH_TIMEOUT_MS=60000

# ─── Public (exposed to browser) ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.medcover.io

# Google Tag Manager container ID (production only — omit locally to skip GTM)
NEXT_PUBLIC_GTM_ID=GTM-TNS8J65R

# ─── Web Bot Auth (RFC draft-ietf-httpbis-web-bot-auth) ────────────────────────
# EC P-256 private key (JWK) for signing outbound HTTP Message Signatures.
# Paired with the public key published at /.well-known/http-message-signatures-directory
# Generate a new pair: node -e "const {generateKeyPairSync}=require('crypto');const {privateKey}=generateKeyPairSync('ec',{namedCurve:'P-256'});console.log(JSON.stringify(privateKey.export({format:'jwk'})))"
WEB_BOT_AUTH_PRIVATE_KEY={"kty":"EC","crv":"P-256","d":"your-private-key-d-value","x":"your-x","y":"your-y","kid":"medcover-bot-key-1","use":"sig","alg":"ES256"}
