# ─── Traffic Engine (NestJS backend) ───────────────────────────────────────────
# Full base URL including /api/v1 — no trailing slash
TRAFFIC_ENGINE_URL=https://nestino-backend-production.up.railway.app/api/v1

# Site credentials (obtained from POST /api/v1/sites in the backend admin)
SITE_API_KEY=your-site-api-key-here
SITE_ID=2

# ─── Revalidation Webhook ──────────────────────────────────────────────────────
# Must match Site.publishWebhookSecret stored in the backend database
WEBHOOK_SECRET=your-shared-webhook-secret-here

# ─── Cache TTL ─────────────────────────────────────────────────────────────────
# How long (seconds) the Next.js fetch cache keeps pages before a background
# refresh. Set lower during development. Webhook revalidation bypasses this.
CONTENT_REVALIDATE_SECONDS=3600

# Optional: fetch timeout in ms (default 60000 dev / 30000 production)
TRAFFIC_ENGINE_FETCH_TIMEOUT_MS=60000

# ─── Public (exposed to browser) ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://medcover.io

# Google Tag Manager container ID (production only — omit locally to skip GTM)
NEXT_PUBLIC_GTM_ID=GTM-TNS8J65R
