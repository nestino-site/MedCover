# ─── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the nestino-backend (no trailing slash)
API_BASE_URL=http://localhost:3001

# Site credentials (obtained from POST /api/v1/sites in the backend admin)
SITE_API_KEY=your-site-api-key-here
SITE_ID=1

# Hostname for backend-served images (for next/image remotePatterns)
API_IMAGE_HOSTNAME=your-cdn-hostname.com

# ─── Revalidation Webhook ──────────────────────────────────────────────────────
# Must match the publishWebhookSecret configured on the Site record in the backend
REVALIDATE_SECRET=your-shared-webhook-secret-here

# ─── Public (exposed to browser) ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://medcover.com
